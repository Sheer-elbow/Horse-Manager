generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STABLE_LEAD
  GROOM
  RIDER
  OWNER
  TRAINER
}

enum MembershipType {
  AUTO
  REQUESTED
  APPROVED
}

enum Permission {
  VIEW
  EDIT
}

enum Slot {
  AM
  PM
}

enum ProgrammeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AppliedPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AppointmentType {
  VET
  FARRIER
  DENTIST
  VACCINATION
  OTHER
}

enum AppointmentStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  CONFIRMED
  PAID
}

enum InvoiceType {
  OWNER
  STABLE
}

// ─── Users & Auth ────────────────────────────────────────────

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String   @map("password_hash")
  name               String?
  role               Role     @default(RIDER)
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  tokenVersion       Int      @default(0) @map("token_version")
  acceptedTermsAt    DateTime? @map("accepted_terms_at")
  acceptedPrivacyAt  DateTime? @map("accepted_privacy_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  assignments              HorseAssignment[]
  stableAssignments        StableAssignment[]
  horsePriorities          HorsePriority[]
  stableMemberships        StableMembership[]
  invitesSent              InviteToken[]
  passwordResetTokens      PasswordResetToken[]
  createdProgrammes        Programme[]
  sessionLogs              ActualSessionLog[]
  auditEdits               SessionAuditLog[]
  assignedPlans            AppliedPlan[]
  sharedPlans              PlanShare[]
  notificationPreference   NotificationPreference?
  securityEvents           SecurityEvent[]
  appointments             Appointment[]
  createdInvoices              Invoice[]                @relation("InvoiceCreator")
  ownedInvoiceSplits           InvoiceSplit[]            @relation("InvoiceSplitOwner")
  createdRecurringInvoices     RecurringInvoice[]        @relation("RecurringInvoiceCreator")
  ownedRecurringInvoiceSplits  RecurringInvoiceSplit[]   @relation("RecurringInvoiceSplitOwner")
  uploadedDocuments            HorseDocument[]           @relation("DocumentUploader")
  ownedStables                 Stable[]                  @relation("StableOwner")

  @@map("users")
}

model InviteToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  role      Role      @default(RIDER)
  createdBy String    @map("created_by")
  creator   User      @relation(fields: [createdBy], references: [id])
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("invite_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  // SHA-256 of the raw token — raw token only travels in the reset email link
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── Stables ─────────────────────────────────────────────────

model Stable {
  id        String   @id @default(uuid())
  name      String   @unique
  address   String?
  latitude  Float?
  longitude Float?
  ownerId   String?  @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner               User?              @relation("StableOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  horses              Horse[]
  stableAssignments   StableAssignment[]
  stableMemberships   StableMembership[]
  invoices            Invoice[]
  recurringInvoices   RecurringInvoice[]

  @@map("stables")
}

// ─── Horses ──────────────────────────────────────────────────

model Horse {
  id              String   @id @default(uuid())
  name            String
  age             Int?
  breed           String?
  ownerNotes      String?  @map("owner_notes")
  stableLocation  String?  @map("stable_location")
  stableId        String?  @map("stable_id")
  identifyingInfo String?  @map("identifying_info")
  photoUrl        String?  @map("photo_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  stable          Stable?  @relation(fields: [stableId], references: [id], onDelete: SetNull)
  assignments     HorseAssignment[]
  priorities      HorsePriority[]
  planBlocks      PlanBlock[]
  plannedSessions PlannedSession[]
  actualSessions  ActualSessionLog[]
  appliedPlans    AppliedPlan[]
  workouts        Workout[]
  vetVisits       VetVisit[]
  farrierVisits   FarrierVisit[]
  dentistVisits   DentistVisit[]
  vaccinations    VaccinationRecord[]
  expenses                  ExpenseNote[]
  appointments              Appointment[]
  invoiceSplits             InvoiceSplit[]
  recurringInvoiceSplits    RecurringInvoiceSplit[]
  documents                 HorseDocument[]

  @@map("horses")
}

model HorseAssignment {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  horseId    String     @map("horse_id")
  permission Permission @default(VIEW)
  createdAt  DateTime   @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@unique([userId, horseId])
  @@map("horse_assignments")
}

// ─── Programmes & Plans ──────────────────────────────────────

model Programme {
  id               String            @id @default(uuid())
  name             String
  description      String?
  htmlContent      String?           @map("html_content") @db.Text
  originalFileName String?           @map("original_file_name")
  horseNames       String[]          @map("horse_names")
  status           ProgrammeStatus?  @map("status")
  latestVersionId  String?           @map("latest_version_id")
  createdById      String            @map("created_by_id")
  createdBy        User              @relation(fields: [createdById], references: [id])
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  planBlocks PlanBlock[]
  versions   ProgrammeVersion[]

  @@map("programmes")
}

model PlanBlock {
  id            String     @id @default(uuid())
  horseId       String     @map("horse_id")
  programmeId   String?    @map("programme_id")
  appliedPlanId String?    @map("applied_plan_id")
  name          String
  startDate     DateTime   @map("start_date") @db.Date
  numWeeks      Int        @default(6) @map("num_weeks")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  horse       Horse        @relation(fields: [horseId], references: [id], onDelete: Cascade)
  programme   Programme?   @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  appliedPlan AppliedPlan? @relation(fields: [appliedPlanId], references: [id], onDelete: SetNull)
  sessions    PlannedSession[]

  @@map("plan_blocks")
}

model PlannedSession {
  id              String   @id @default(uuid())
  planBlockId     String   @map("plan_block_id")
  horseId         String   @map("horse_id")
  workoutId       String?  @map("workout_id")
  date            DateTime @db.Date
  slot            Slot
  sessionType     String?  @map("session_type")
  description     String?
  durationMinutes Int?     @map("duration_minutes")
  intensityRpe    Int?     @map("intensity_rpe")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  planBlock     PlanBlock         @relation(fields: [planBlockId], references: [id], onDelete: Cascade)
  horse         Horse             @relation(fields: [horseId], references: [id], onDelete: Cascade)
  workout       Workout?          @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  actualSession ActualSessionLog?

  @@index([horseId, date, slot])
  @@map("planned_sessions")
}

// ─── Programme Versions & Applied Plans ──────────────────────

model ProgrammeVersion {
  id             String           @id @default(uuid())
  programmeId    String           @map("programme_id")
  version        Int
  status         ProgrammeStatus  @default(DRAFT)
  numWeeks       Int              @map("num_weeks")
  manualHtml     String?          @map("manual_html") @db.Text
  manualFileName String?          @map("manual_file_name")
  scheduleData   Json             @map("schedule_data")
  publishedAt    DateTime?        @map("published_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  programme    Programme     @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  appliedPlans AppliedPlan[]

  @@unique([programmeId, version])
  @@map("programme_versions")
}

model AppliedPlan {
  id                  String            @id @default(uuid())
  horseId             String            @map("horse_id")
  programmeVersionId  String            @map("programme_version_id")
  assignedById        String            @map("assigned_by_id")
  startDate           DateTime          @map("start_date") @db.Date
  status              AppliedPlanStatus @default(ACTIVE)
  sourceAppliedPlanId String?           @map("source_applied_plan_id")
  isAmended           Boolean           @default(false) @map("is_amended")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  horse             Horse             @relation(fields: [horseId], references: [id], onDelete: Cascade)
  programmeVersion  ProgrammeVersion  @relation(fields: [programmeVersionId], references: [id])
  assignedBy        User              @relation(fields: [assignedById], references: [id])
  sourceAppliedPlan AppliedPlan?      @relation("AppliedPlanRepeat", fields: [sourceAppliedPlanId], references: [id], onDelete: SetNull)
  derivedPlans      AppliedPlan[]     @relation("AppliedPlanRepeat")
  planBlocks        PlanBlock[]
  workouts          Workout[]
  shares            PlanShare[]

  @@map("applied_plans")
}

model Workout {
  id            String    @id @default(uuid())
  appliedPlanId String    @map("applied_plan_id")
  horseId       String    @map("horse_id")
  originWeek    Int       @map("origin_week")
  originDay     Int       @map("origin_day")
  scheduledDate DateTime? @map("scheduled_date") @db.Date
  slot          Slot      @default(AM)
  baselineData  Json      @map("baseline_data")
  currentData   Json      @map("current_data")
  isRest        Boolean   @default(false) @map("is_rest")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  appliedPlan     AppliedPlan      @relation(fields: [appliedPlanId], references: [id], onDelete: Cascade)
  horse           Horse            @relation(fields: [horseId], references: [id], onDelete: Cascade)
  plannedSessions PlannedSession[]

  @@map("workouts")
}

model PlanShare {
  id            String     @id @default(uuid())
  appliedPlanId String     @map("applied_plan_id")
  sharedWithId  String     @map("shared_with_id")
  permission    Permission
  createdAt     DateTime   @default(now()) @map("created_at")

  appliedPlan AppliedPlan @relation(fields: [appliedPlanId], references: [id], onDelete: Cascade)
  sharedWith  User        @relation(fields: [sharedWithId], references: [id], onDelete: Cascade)

  @@unique([appliedPlanId, sharedWithId])
  @@map("plan_shares")
}

// ─── Session Logging & Audit ─────────────────────────────────

model ActualSessionLog {
  id               String   @id @default(uuid())
  horseId          String   @map("horse_id")
  date             DateTime @db.Date
  slot             Slot
  plannedSessionId String?  @unique @map("planned_session_id")
  sessionType      String?  @map("session_type")
  durationMinutes  Int?     @map("duration_minutes")
  intensityRpe     Int?     @map("intensity_rpe")
  notes            String?
  rider            String?
  deviationReason  String?  @map("deviation_reason")
  createdById      String   @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  horse          Horse            @relation(fields: [horseId], references: [id], onDelete: Cascade)
  plannedSession PlannedSession?  @relation(fields: [plannedSessionId], references: [id], onDelete: SetNull)
  createdBy      User             @relation(fields: [createdById], references: [id])
  auditLogs      SessionAuditLog[]

  @@index([horseId, date, slot])
  @@map("actual_session_logs")
}

model SessionAuditLog {
  id                 String   @id @default(uuid())
  actualSessionLogId String   @map("actual_session_log_id")
  editedById         String   @map("edited_by_id")
  editedAt           DateTime @default(now()) @map("edited_at")
  previousData       Json     @map("previous_data")
  newData            Json     @map("new_data")

  actualSessionLog ActualSessionLog @relation(fields: [actualSessionLogId], references: [id], onDelete: Cascade)
  editedBy         User             @relation(fields: [editedById], references: [id])

  @@map("session_audit_logs")
}

// ─── Notification Preferences ────────────────────────────────

model NotificationPreference {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Master switch — when false nothing is sent regardless of other settings
  emailEnabled Boolean @default(false) @map("email_enabled")

  // Health: vaccination reminders (null = off, otherwise X days before due date)
  vaccinationReminderDays Int? @map("vaccination_reminder_days")

  // Health: overdue vaccination alert
  overdueVaccinationAlert Boolean @default(false) @map("overdue_vaccination_alert")

  // Health: vet check-up reminder (null = off, otherwise alert if no visit in X days)
  vetCheckupReminderDays Int? @map("vet_checkup_reminder_days")

  // Health: farrier reminder (null = off, otherwise alert if no visit in X days)
  farrierReminderDays Int? @map("farrier_reminder_days")

  // Training: end-of-day reminder if sessions went unlogged
  unloggedSessionAlert Boolean @default(false) @map("unlogged_session_alert")

  // Training: Monday morning weekly digest of the week ahead
  weeklyDigest Boolean @default(false) @map("weekly_digest")

  // Appointments: reminder X days before (null = off)
  appointmentReminderDays Int? @map("appointment_reminder_days")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

// ─── Stable Manager (health / expenses) ─────────────────────

model VetVisit {
  id           String    @id @default(uuid())
  horseId      String    @map("horse_id")
  date         DateTime  @db.Date
  vetName      String?   @map("vet_name")
  visitReason  String?   @map("visit_reason")
  notes        String?
  dueDate      DateTime? @map("due_date") @db.Date
  fileUrl      String?   @map("file_url")
  fileName     String?   @map("file_name")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@map("vet_visits")
}

model FarrierVisit {
  id          String    @id @default(uuid())
  horseId     String    @map("horse_id")
  date        DateTime  @db.Date
  farrierName String?   @map("farrier_name")
  notes       String?
  dueDate     DateTime? @map("due_date") @db.Date
  fileUrl     String?   @map("file_url")
  fileName    String?   @map("file_name")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@map("farrier_visits")
}

model DentistVisit {
  id          String    @id @default(uuid())
  horseId     String    @map("horse_id")
  date        DateTime  @db.Date
  dentistName String?   @map("dentist_name")
  notes       String?
  dueDate     DateTime? @map("due_date") @db.Date
  fileUrl     String?   @map("file_url")
  fileName    String?   @map("file_name")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@map("dentist_visits")
}

model VaccinationRecord {
  id        String    @id @default(uuid())
  horseId   String    @map("horse_id")
  name      String?
  date      DateTime  @db.Date
  notes     String?
  dueDate   DateTime? @map("due_date") @db.Date
  fileUrl   String?   @map("file_url")
  fileName  String?   @map("file_name")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@map("vaccination_records")
}

model ExpenseNote {
  id        String   @id @default(uuid())
  horseId   String   @map("horse_id")
  date      DateTime @db.Date
  category  String?
  amount    Decimal? @db.Decimal(10, 2)
  notes     String?
  fileUrl   String?  @map("file_url")
  fileName  String?  @map("file_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@map("expense_notes")
}

// ─── Stable Assignments (staff linked to stables) ────────────

model StableAssignment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  stableId  String   @map("stable_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  stable Stable @relation(fields: [stableId], references: [id], onDelete: Cascade)

  @@unique([userId, stableId])
  @@map("stable_assignments")
}

// ─── Horse Priorities (priority care horses for stable staff) ─

model HorsePriority {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  horseId   String   @map("horse_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@unique([userId, horseId])
  @@map("horse_priorities")
}

// ─── Stable Memberships (owners linked to stables) ───────────

model StableMembership {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  stableId  String         @map("stable_id")
  type      MembershipType @default(AUTO)
  createdAt DateTime       @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  stable Stable @relation(fields: [stableId], references: [id], onDelete: Cascade)

  @@unique([userId, stableId])
  @@map("stable_memberships")
}

// ─── Security Events ──────────────────────────────────────────

enum SecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  ROLE_CHANGED
  USER_DELETED
  INVITE_SENT
  INVITE_ACCEPTED
  TOKEN_REFRESHED
  PASSWORD_RESET_USED
  SUSPICIOUS_ACTIVITY
  USER_REGISTERED
}

model SecurityEvent {
  id         String            @id @default(uuid())
  eventType  SecurityEventType @map("event_type")
  userId     String?           @map("user_id")
  email      String?
  ipAddress  String?           @map("ip_address")
  userAgent  String?           @map("user_agent")
  outcome    String
  metadata   Json?
  createdAt  DateTime          @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([ipAddress, createdAt])
  @@map("security_events")
}

// ─── Appointments ─────────────────────────────────────────────

model Appointment {
  id               String            @id @default(uuid())
  horseId          String            @map("horse_id")
  createdById      String            @map("created_by_id")
  type             AppointmentType
  typeOther        String?           @map("type_other")
  scheduledAt      DateTime          @map("scheduled_at")
  practitionerName String?           @map("practitioner_name")
  contactNumber    String?           @map("contact_number")
  locationAtStable Boolean           @default(true) @map("location_at_stable")
  locationOther    String?           @map("location_other")
  notes            String?
  status           AppointmentStatus @default(UPCOMING)
  reminderSent     Boolean           @default(false) @map("reminder_sent")
  completedAt      DateTime?         @map("completed_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  horse     Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id])

  @@index([horseId, scheduledAt])
  @@index([status, scheduledAt])
  @@map("appointments")
}

// ─── Invoices & Cost Splitting ────────────────────────────────

model Invoice {
  id                 String        @id @default(uuid())
  type               InvoiceType   @default(OWNER)
  createdById        String        @map("created_by_id")
  stableId           String?       @map("stable_id")
  recurringInvoiceId String?       @map("recurring_invoice_id")
  supplier           String?
  category           String
  date               DateTime      @db.Date
  totalAmount        Decimal       @db.Decimal(10, 2) @map("total_amount")
  notes              String?
  fileUrl            String?       @map("file_url")
  fileName           String?       @map("file_name")
  status             InvoiceStatus @default(DRAFT)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  createdBy        User              @relation("InvoiceCreator", fields: [createdById], references: [id])
  stable           Stable?           @relation(fields: [stableId], references: [id], onDelete: SetNull)
  recurringInvoice RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id], onDelete: SetNull)
  splits           InvoiceSplit[]

  @@index([createdById, date])
  @@index([stableId, date])
  @@map("invoices")
}

model InvoiceSplit {
  id        String   @id @default(uuid())
  invoiceId String   @map("invoice_id")
  horseId   String   @map("horse_id")
  ownerId   String?  @map("owner_id")
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  horse   Horse   @relation(fields: [horseId], references: [id], onDelete: Cascade)
  owner   User?   @relation("InvoiceSplitOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@map("invoice_splits")
}

// ─── Recurring Invoices ───────────────────────────────────────

model RecurringInvoice {
  id                String      @id @default(uuid())
  type              InvoiceType @default(OWNER)
  createdById       String      @map("created_by_id")
  stableId          String?     @map("stable_id")
  supplier          String?
  category          String
  totalAmount       Decimal     @db.Decimal(10, 2) @map("total_amount")
  notes             String?
  active            Boolean     @default(true)
  dayOfMonth        Int         @default(1) @map("day_of_month")
  startDate         DateTime    @db.Date @map("start_date")
  endDate           DateTime?   @db.Date @map("end_date")
  lastGeneratedDate DateTime?   @db.Date @map("last_generated_date")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  createdBy User                   @relation("RecurringInvoiceCreator", fields: [createdById], references: [id])
  stable    Stable?                @relation(fields: [stableId], references: [id], onDelete: SetNull)
  splits    RecurringInvoiceSplit[]
  invoices  Invoice[]

  @@index([createdById, active])
  @@map("recurring_invoices")
}

model RecurringInvoiceSplit {
  id                 String   @id @default(uuid())
  recurringInvoiceId String   @map("recurring_invoice_id")
  horseId            String   @map("horse_id")
  ownerId            String?  @map("owner_id")
  amount             Decimal  @db.Decimal(10, 2)
  createdAt          DateTime @default(now()) @map("created_at")

  recurringInvoice RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)
  horse            Horse            @relation(fields: [horseId], references: [id], onDelete: Cascade)
  owner            User?            @relation("RecurringInvoiceSplitOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@map("recurring_invoice_splits")
}

// ─── Horse Documents ──────────────────────────────────────────

model HorseDocument {
  id           String    @id @default(uuid())
  horseId      String    @map("horse_id")
  uploadedById String    @map("uploaded_by_id")
  name         String
  category     String    @default("Other")
  fileUrl      String    @map("file_url")
  fileName     String    @map("file_name")
  expiresAt    DateTime? @db.Date @map("expires_at")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  horse      Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([horseId, category])
  @@index([expiresAt])
  @@map("horse_documents")
}
